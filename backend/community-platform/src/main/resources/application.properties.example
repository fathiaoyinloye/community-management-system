# ===== Base (common to all environments) =====
spring.application.name=community-platform
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.output.ansi.enabled=ALWAYS
spring.profiles.active=dev

# ===== DEV profile values (copy into application-dev.properties) =====
spring.datasource.url=jdbc:postgresql://localhost:5432/your_db_name
spring.datasource.username=your_username
spring.datasource.password=your_password
spring.datasource.driver-class-name=org.postgresql.Driver
logging.level.com.semicolon.communitymanagementsystem=DEBUG
logging.level.org.hibernate.orm.jdbc.bind=TRACE

# ===== PROD profile values (copy into application-prod.properties, use real env vars) =====
# spring.datasource.url=${DATABASE_URL}
# spring.datasource.username=${DB_USERNAME}
# spring.datasource.password=${DB_PASSWORD}
# logging.level.org.hibernate.orm.jdbc.bind=WARN
# spring.jpa.show-sql=false